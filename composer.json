{
    "name": "laravel-ready/tool",
    "description": "CLI: уровень готовности PHP-файлов к миграции в Laravel",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "illuminate/support": "^13.0",
        "nikic/php-parser": "^5.7",
        "symfony/console": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2",
        "phpstan/phpstan": "^2.2",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "LaravelReady\\": "src/"
        }
    },
    "bin": [
        "bin/laravel-ready"
    ],
    "minimum-stability": "stable"
}
