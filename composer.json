{
  "name": "laravel-ready/tool",
  "description": "CLI: уровень готовности PHP-файлов к миграции в Laravel",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.5",
    "illuminate/support": "^13.0",
    "nikic/php-parser": "^5.7",
    "symfony/console": "^8.1",
    "illuminate/filesystem": "^13.0"
  },
  "require-dev": {
    "laravel/pint": "^1.29",
    "pestphp/pest": "^4.0",
    "phpstan/phpstan": "^2.2",
    "symfony/var-dumper": "^8.1"
  },
  "autoload": {
    "psr-4": {
      "LaravelReady\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LaravelReady\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "hooks": "bash .git_hooks/install.sh",
    "phpstan": "phpstan analyse",
    "pint": "pint",
    "pint:test": "pint --test",
    "test": "pest",
    "test-dock": "docker run --rm -v .:/app -w /app laravel-ready-dev composer test",
    "phpstan-dock": "docker run --rm -v .:/app -w /app laravel-ready-dev composer phpstan",
    "pint-dock": "docker run --rm -v .:/app -w /app laravel-ready-dev composer pint",
    "pint-test-dock": "docker run --rm -v .:/app -w /app laravel-ready-dev composer pint:test",
    "check-dock": "docker run --rm -v .:/app -w /app laravel-ready-dev sh -c \"composer phpstan && composer pint:test && composer test\"",
    "test-cov": "docker run --rm -v .:/app -w /app laravel-ready-dev composer test -- --coverage-html build/coverage",
    "test-mut": "docker run --rm -v .:/app -w /app laravel-ready-dev vendor/bin/pest --mutate --covered-only",
    "test-mut-all": "docker run --rm -v .:/app -w /app laravel-ready-dev vendor/bin/pest --mutate"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "bin": [
    "bin/laravel-ready"
  ],
  "minimum-stability": "stable"
}
