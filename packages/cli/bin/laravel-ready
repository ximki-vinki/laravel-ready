#!/usr/bin/env php
<?php

declare(strict_types=1);

$binary = dirname(__DIR__).'/bin/laravel-ready.exe';

if (is_file($binary)) {
    $command = escapeshellarg($binary);

    foreach (array_slice($argv, 1) as $argument) {
        $command .= ' '.escapeshellarg($argument);
    }

    passthru($command, $exitCode);

    exit($exitCode);
}

fwrite(STDERR, "laravel-ready.exe not found. Run: composer install\n");
exit(1);
